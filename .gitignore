# Build tree — fully regenerated by build.sh on every run (it does `rm -rf build/`).
# Contains fetched upstream kwin tarballs, the extracted source, and the built
# packages (hundreds of MB). Never commit it.
/build/

# Build logs / transcripts
*.log

# Local Claude Code settings (machine-specific, may contain local paths)
/.claude/

# Editor / OS cruft
*.swp
*~
.DS_Store
